# Copy to .env and fill when hackathon Fireworks credits unlock (stub brief works if empty)
FIREWORKS_API_KEY=
FIREWORKS_MODEL=accounts/fireworks/models/glm-5p2
BACKEND_URL=http://localhost:8000
# DEMO_DATA_DIR: leave unset for local dev (defaults to <repo>/data/demo).
# Relative paths resolve against the repo root regardless of cwd.
# In Docker, docker-compose sets this to /app/data/demo.
# DEMO_DATA_DIR=data/demo
INFERENCE_MODE=stub
XVIEW2_DOCKER_IMAGE=darknem-xview2-inference
# PYTORCH_CHECKPOINT_PATH: leave unset to use the repo-root default
# (<repo>/ml/checkpoints/damage_best.ckpt). Relative paths resolve against
# the repo root, so cwd=backend/ still works.
# PYTORCH_CHECKPOINT_PATH=ml/checkpoints/damage_best.ckpt
PYTORCH_DOCKER_IMAGE=darknem-xview2-pytorch
